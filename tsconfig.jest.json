{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "es2020",
    "target": "ES2020",
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["jest", "node", "@testing-library/jest-dom", "vite/client"],
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "skipLibCheck": true
  }
}
